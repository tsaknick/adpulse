# Copy this file to .env.local and fill in your credentials.
# Use these redirect URIs in Google / Meta / TikTok:
# http://127.0.0.1:5173/api/auth/google_ads/callback
# http://127.0.0.1:5173/api/auth/ga4/callback
# http://127.0.0.1:5173/api/auth/meta_ads/callback
# http://127.0.0.1:5173/api/auth/tiktok_ads/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=

META_APP_ID=
META_APP_SECRET=
# Optional if you use Facebook Login for Business.
META_CONFIG_ID=

TIKTOK_APP_ID=
TIKTOK_APP_SECRET=

# Optional: enables the AI strategist layer in Accounts and Search Terms.
ANTHROPIC_API_KEY=
ANTHROPIC_STRATEGIST_MODEL=claude-sonnet-4-6
